rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function authUserPath() {
      return /databases/$(database)/documents/auth_users/$(request.auth.uid);
    }

    function hasAuthUser() {
      return signedIn() && exists(authUserPath());
    }

    function authUser() {
      return get(authUserPath()).data;
    }

    function couplePath(coupleId) {
      return /databases/$(database)/documents/couples/$(coupleId);
    }

    function isCoupleMember(coupleId) {
      return hasAuthUser()
        && exists(couplePath(coupleId))
        && authUser().linkedCoupleId == coupleId
        && get(couplePath(coupleId)).data.memberIds.hasAny([authUser().userId])
        && get(couplePath(coupleId)).data.authUids.hasAny([request.auth.uid]);
    }

    function sameCoupleMembers() {
      return resource.data.memberIds.hasAll(request.resource.data.memberIds)
        && request.resource.data.memberIds.hasAll(resource.data.memberIds);
    }

    function canJoinDeclaredCouple() {
      return hasAuthUser()
        && resource.data.memberIds.hasAny([authUser().userId])
        && request.resource.data.memberIds.size() <= 2
        && sameCoupleMembers()
        && request.resource.data.authUids.hasAll(resource.data.authUids)
        && request.resource.data.authUids.hasAny([request.auth.uid]);
    }

    match /auth_users/{authUid} {
      allow get, create, update: if signedIn() && authUid == request.auth.uid;
      allow list, delete: if false;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn();
      allow delete: if false;
    }

    match /login_ids/{loginId} {
      allow get, create, update: if signedIn();
      allow list, delete: if false;
    }

    match /couple_codes/{code} {
      allow get, create, update: if signedIn();
      allow list, delete: if false;
    }

    match /emails/{email} {
      allow get, create, update: if signedIn();
      allow list, delete: if false;
    }

    match /email_verification_requests/{requestId} {
      allow get, create, update: if signedIn();
      allow list, delete: if false;
    }

    match /mail/{mailId} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }

    match /couples/{coupleId} {
      allow get: if signedIn();
      allow list: if isCoupleMember(coupleId);
      allow create: if signedIn()
        && request.resource.data.authUids.hasAny([request.auth.uid])
        && request.resource.data.memberIds.size() <= 2;
      allow update: if isCoupleMember(coupleId) || canJoinDeclaredCouple();
      allow delete: if false;

      match /{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
    }
  }
}
